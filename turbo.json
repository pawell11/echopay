{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", "tsconfig.json"],
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_SOLANA_RPC",
    "NEXT_PUBLIC_ECHO_TOKEN_MINT",
    "NEXT_PUBLIC_API_URL",
    "VANTAGEPAY_API_KEY",
    "VANTAGEPAY_ISSUER_ENDPOINT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "target/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}