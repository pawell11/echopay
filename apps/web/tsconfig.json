{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@vantagepay/ui": [
        "../../packages/ui/src"
      ],
      "@vantagepay/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@vantagepay/hooks": [
        "../../packages/hooks/src"
      ],
      "@vantagepay/utils": [
        "../../packages/utils/src"
      ],
      "@vantagepay/api": [
        "../../packages/api/src"
      ],
      "@vantagepay/config": [
        "../../packages/config"
      ]
    },
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
