# ─── VantagePay Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in the values.
# cp .env.example .env

# ── Solana RPC ──────────────────────────────────────────────────────
# Helius, QuickNode, Triton, or public RPC endpoint
NEXT_PUBLIC_SOLANA_RPC="https://api.mainnet-beta.solana.com"

# ── VantagePay API ─────────────────────────────────────────────────────
# API base URL (defaults to /api for same-origin in dev)
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# ── Card Issuer (mock in dev, real provider in prod) ─────────────────
# Production card issuer endpoint (Marqeta, Stripe Issuing, etc.)
VANTAGEPAY_ISSUER_ENDPOINT=""

# ── VantagePay API Key (protects internal API routes) ───────────────────
VANTAGEPAY_API_KEY="dev-api-key-change-in-production"

# ── Echo Token ──────────────────────────────────────────────────────
# VantagePay SPL token mint address (placeholder for dev)
NEXT_PUBLIC_ECHO_TOKEN_MINT="Echooooooooooooooooooooooooooooooooooooooooooo"

# ── Feature Flags ───────────────────────────────────────────────────
# Enable KYC tier (set to "true" when KYC provider is integrated)
NEXT_PUBLIC_KYC_ENABLED="false"

# ── Analytics ───────────────────────────────────────────────────────
# NEXT_PUBLIC_ANALYTICS_ID="G-XXXXXXXXXX"
