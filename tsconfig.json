{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@vantagepay/ui": ["./packages/ui/src"],
      "@vantagepay/ui/*": ["./packages/ui/src/*"],
      "@vantagepay/hooks": ["./packages/hooks/src"],
      "@vantagepay/hooks/*": ["./packages/hooks/src/*"],
      "@vantagepay/utils": ["./packages/utils/src"],
      "@vantagepay/utils/*": ["./packages/utils/src/*"],
      "@vantagepay/api": ["./packages/api/src"],
      "@vantagepay/api/*": ["./packages/api/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "target"]
}